# Database Configuration
# For local dev: use Docker PostgreSQL or a local instance
# For PGLite (browser): set to "pglite://local"
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/subway_surfers

# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# CORS Origins (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# App Name (used in PWA manifest)
APP_NAME=Subway Surfers Clone

# Worker Polling Interval (ms) for LISTEN/NOTIFY jobs
WORKER_POLL_INTERVAL_MS=1000

# JWT Secret (for auth if needed later)
JWT_SECRET=change-me-in-production

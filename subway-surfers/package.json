{
  "name": "subway-surfers",
  "version": "1.0.0",
  "description": "A Subway Surfers clone - 3D endless runner game",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "worker": "bun src/worker.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "build:client": "mkdir -p dist && cp -r client/* dist/",
    "build": "bun run build:client",
    "lint": "eslint src/",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@elysiajs/static": "^1.4.10",
    "@tweenjs/tween.js": "^25.0.0",
    "@types/bun": "^1.3.14",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.4",
    "elysia": "^1.2.19",
    "pg": "^8.13.1",
    "three": "^0.172.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/three": "^0.172.0",
    "drizzle-kit": "^0.30.4",
    "typescript": "^5.7.2"
  }
}

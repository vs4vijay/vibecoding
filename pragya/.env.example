# DRISHTI environment variables.
# Copy to .env and adjust. All values are validated at startup.

# --- Web service (Next.js) ---
WEB_PORT=3000
WEB_HOST=localhost
NODE_ENV=development

# Database. In dev, PGLite is used regardless of this URL (controlled by DB_DRIVER).
# In prod, set DB_DRIVER=postgres and a real DATABASE_URL.
DB_DRIVER=pglite
DATABASE_URL=postgres://drishti:drishti@localhost:5432/drishti
PGLITE_DATA_DIR=./pglite-data

# --- ML service (FastAPI) ---
ML_HOST=localhost
ML_PORT=8000
ML_BASE_URL=http://localhost:8000
ML_VERSION=0.1.0

# --- Inter-service auth (dev shared secret) ---
INTERNAL_SHARED_SECRET=dev-only-not-a-secret

# --- Worker ---
WORKER_ID=worker-local
WORKER_POLL_INTERVAL_MS=2000
WORKER_JOB_LOCK_TIMEOUT_MS=60000
WEB_INTERNAL_BASE_URL=http://localhost:3000

# --- Determinism ---
DEFAULT_SEED=42

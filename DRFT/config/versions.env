# DRFT build configuration — single source of truth for upstream pin & toolchain.
# Sourced by every script (POSIX-compatible key=value, no spaces around `=`).
# Override locally by creating `config/versions.local.env` (gitignored).

# ---- DRFT identity --------------------------------------------------------
DRFT_PRODUCT_NAME="DRFT"
# Used to suffix the application ID so DRFT can be installed alongside Focus
# during development. Empty string = same applicationId as upstream Focus.
DRFT_APPLICATION_ID_SUFFIX=".drft"

# ---- Upstream pin ---------------------------------------------------------
# mozilla-firefox/firefox commit hash. Updating this is how we "rebase".
# The current value matches the commit IronFox is currently building against
# (Firefox 150.0.3), so we know it produces a working APK.
FIREFOX_REPO="mozilla-firefox/firefox"
FIREFOX_REV="a077abc2b0f43ed7cc59a8bfcd873e683500d23a"
# Human-readable label for log/release output. Bump alongside FIREFOX_REV.
FIREFOX_VERSION="150.0.3"

# ---- Build target ---------------------------------------------------------
# Gradle module path (relative to the extracted firefox tree).
FOCUS_MODULE_PATH="mobile/android/focus-android"
# Build variant to assemble by default. Override via DRFT_VARIANT env var.
# Useful variants:
#   focusDebug  | focusRelease  | focusBeta  | focusNightly
#   klarDebug   | klarRelease   | klarBeta   | klarNightly
DRFT_VARIANT="focusDebug"

# ---- Toolchain pins -------------------------------------------------------
# JDK: focus-android currently targets JDK 21 (matches mozilla-central's
# Android Gradle Plugin requirement). Newer Mozilla revs may bump this.
JDK_VERSION="21"
# Android cmdline-tools & build artifacts. CI installs via setup-android.
ANDROID_COMPILE_SDK="35"
ANDROID_BUILD_TOOLS="35.0.0"
ANDROID_NDK_VERSION="27.2.12479018"

# ---- Paths (resolved at runtime; do not set absolute paths here) ----------
# All write-scratch lives under build/ to keep cleanup trivial.
DRFT_BUILD_DIR_NAME="build"
DRFT_SRC_DIR_NAME="firefox-src"
DRFT_DIST_DIR_NAME="dist"

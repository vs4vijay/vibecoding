# GitHub Configuration
GITHUB_TOKEN=
GITHUB_OWNER=vs4vijay
GITHUB_REPO=CrowdCode

# OpenCode CLI Configuration
# Install OpenCode: curl -fsSL https://opencode.ai/install | bash
# Then authenticate with your preferred provider
# OpenCode supports: Anthropic, OpenAI, Google Gemini, Azure, and more

# OpenCode Model (format: provider/model)
# Examples:
#   - anthropic/claude-sonnet-4-20250514 (default)
#   - openai/gpt-4.1
#   - google/gemini-2.0-flash
OPENCODE_MODEL=anthropic/claude-sonnet-4-20250514

# API Keys (required based on your chosen provider)
# Set the appropriate key for your model provider:
# ANTHROPIC_API_KEY=your_anthropic_key
# OPENAI_API_KEY=your_openai_key
# GOOGLE_API_KEY=your_google_key

# Repository Configuration
ISSUE_LABEL=crowdcode
MIN_REACTIONS=1
MIN_ISSUE_AGE_HOURS=24

# Execution Configuration
WORKSPACE_PATH=./workspace
TIMEOUT_MINUTES=30

# Cron Configuration (optional)
# Format: interval in minutes (default: 1440 = 24 hours)
CRON_INTERVAL_MINUTES=1440

# OCI Configuration - Default

# Copy to .env and configure, or use one of the preset configs:
#   .env.arm   - ARM Always Free (4 OCPUs, 24GB RAM)
#   .env.amd   - AMD Always Free (1 OCPU, 1GB RAM)

OCI_REGION=eu-frankfurt-1
OCI_PRIVATE_KEY_FILENAME=~/.oci/oci_api_key.pem

# Instance Configuration
OCI_SUBNET_ID=
OCI_IMAGE_ID=
OCI_SHAPE=VM.Standard.A1.Flex
OCI_OCPUS=4
OCI_MEMORY_IN_GBS=24
OCI_SSH_PUBLIC_KEY=

# Telegram Notification (optional)
# TELEGRAM_BOT_API_KEY=
# TELEGRAM_USER_ID=

# Loop Mode
LOOP_MODE=false
LOOP_INTERVAL_MIN=60
LOOP_INTERVAL_MAX=120
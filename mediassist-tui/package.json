{
  "name": "mediassist-tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Terminal UI for Medi Assist portal — submit OPD claims with auto-extraction from PDF/image",
  "scripts": {
    "start": "bun run src/index.ts",
    "cli": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun run build.ts",
    "build:windows": "bun run build.ts --target=bun-windows-x64",
    "build:linux": "bun run build.ts --target=bun-linux-x64",
    "build:macos-intel": "bun run build.ts --target=bun-darwin-x64",
    "build:macos-arm": "bun run build.ts --target=bun-darwin-arm64",
    "build:all": "bun run build:windows && bun run build:linux && bun run build:macos-intel && bun run build:macos-arm"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@napi-rs/canvas": "^1.0.0",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "tesseract.js": "^7.0.0",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "bun-types": "^1.3.13",
    "typescript": "^5.6.3"
  }
}

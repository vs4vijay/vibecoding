# Medi Assist credentials (only username + session cookie are persisted; password is never stored)
MEDIASSIST_USER=
MEDIASSIST_COOKIE=
MEDIASSIST_COOKIE_EXPIRES_AT=

# Optional: enable local Ollama LLM fallback for document extraction.
# Pure regex/OCR-based extraction is used by default. Uncomment + `ollama pull qwen2.5:3b`
# to enable LLM gap-filling for tougher documents.
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:3b

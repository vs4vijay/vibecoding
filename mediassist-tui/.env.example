# Medi Assist credentials (only username + session cookie are persisted; password is never stored)
MEDIASSIST_USER=
MEDIASSIST_COOKIE=
MEDIASSIST_COOKIE_EXPIRES_AT=

# ---- Document extraction engines (pluggable) ----
# Defaults below; uncomment to override.
# TEXT_EXTRACTOR=unpdf          # PDF → text. Future: markitdown
# OCR_ENGINE=tesseract          # Image → text. Future: paddleocr, native-tesseract
# FIELD_EXTRACTORS=heuristic,ollama   # Comma-separated chain; first that fills the gaps wins
# TESSERACT_LANGS=eng,hin       # OCR languages

# Optional: local Ollama LLM gap-filler for tougher documents
# Setup: `ollama pull qwen2.5:3b` then uncomment the line below
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:3b
